{
	admin off
	http_port 9080
}

http://localhost:9080 {
	# Static configured app: reverse-bin always spawns a child Caddy file server
	# and proxies this route to its fixed TCP upstream.
	handle_path /static-detector/static/* {
		reverse-bin {
			exec ./tmp/caddy file-server --listen 127.0.0.1:19081 --root ./examples/reverse-proxy/apps/static
			reverse_proxy_to 127.0.0.1:19081
			health_check GET /
		}
	}

	# Static configured app: reverse-bin always spawns the Go echo child process
	# and proxies this route to its fixed Unix-socket upstream.
	handle_path /static-detector/echo/* {
		reverse-bin {
			exec ./examples/reverse-proxy/apps/go-echo/go-echo
			reverse_proxy_to unix//tmp/reverse-bin-go-echo.sock
			env SOCKET_PATH=/tmp/reverse-bin-go-echo.sock
		}
	}

	# Dynamic configured apps: one reverse-bin route calls the detector for each
	# app path. The detector inspects examples/reverse-proxy/apps/<app> and emits
	# JSON for either an index.html static app or an executable app binary.
	handle_path /dynamic-detector/* {
		reverse-bin {
			dynamic_proxy_detector ./examples/reverse-proxy/detector/example-detector {path}
		}
	}
}
